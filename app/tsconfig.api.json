{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "5.0",
    "outDir": ".api-dist",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "api/**/*.ts",
    "db/**/*.ts",
    "src/constants/token.ts",
    "src/lib/brandAssetFilenames.ts",
    "src/lib/cetAiConstants.ts",
    "src/lib/cetContract.ts",
    "src/lib/dedustUrls.ts"
  ]
}
