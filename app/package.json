{
  "name": "solaris-cet",
  "description": "Solaris CET — Real-World Asset Token landing page on TON Blockchain. Powered by the RAV Protocol with dual-AI: Grok × Gemini.",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "Solaris CET Team",
    "url": "https://github.com/Solaris-CET"
  },
  "homepage": "https://solaris-cet.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Solaris-CET/solaris-cet.git"
  },
  "keywords": [
    "solaris",
    "cet",
    "ton",
    "blockchain",
    "rwa",
    "real-world-asset",
    "defi",
    "token",
    "dedust",
    "rav-protocol",
    "react",
    "typescript",
    "vite"
  ],
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "predev": "node ../scripts/sync-sovereign-to-public.mjs && node ../scripts/sync-apocalypse-to-public.mjs && node ../scripts/sync-onnxruntime-assets.mjs && node ../scripts/inject-sovereign-build-seal.mjs",
    "dev": "vite",
    "prebuild": "node ../scripts/sync-sovereign-to-public.mjs && node ../scripts/sync-apocalypse-to-public.mjs && node ../scripts/sync-onnxruntime-assets.mjs && node ../scripts/inject-sovereign-build-seal.mjs",
    "build": "tsc -b && vite build",
    "start": "vite preview --host 0.0.0.0 --port ${PORT:-4173}",
    "api:build": "tsc -p tsconfig.api.json",
    "start:node": "node server/index.cjs",
    "start:full": "npm run build && npm run api:build && npm run start:node",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.e2e.json",
    "lint": "eslint .",
    "audit:swarm": "node ../scripts/swarm-audit/audit-processor.mjs",
    "preview": "vite preview",
    "preview:e2e": "NODE_OPTIONS=--max-old-space-size=8192 vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pretest:e2e": "node ../scripts/check-dist-for-e2e.mjs",
    "test:e2e": "playwright test",
    "test:e2e:stable": "PW_WORKERS=1 npm run test:e2e",
    "test:e2e:fresh": "npm run build && npm run test:e2e:stable",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "verify:all": "npm run verify && npm run test:e2e:stable",
    "verify:full": "npm run verify:all",
    "continue": "bash ../scripts/continue-from-here.sh",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fontsource/syne": "^5.2.7",
