# ─────────────────────────────────────────────────────────────────────────────
# Solaris CET — Environment Variables Template
# Copy this file to .env.local for local development.
# In production, set these in Coolify (or your host) environment — never commit keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Master encryption secret ──────────────────────────────────────────────────
# A random passphrase used to encrypt/decrypt API keys with AES-256-GCM.
# Generate a strong value with:  openssl rand -base64 32
# Required when using *_ENC variants of API key env vars.
ENCRYPTION_SECRET=

# ── Grok API (xAI) ───────────────────────────────────────────────────────────
# Powers the ACT + VERIFY phases of the RAV Protocol.
# Obtain your key at: https://console.x.ai/
#
# PREFERRED (encrypted):
#   Encrypt your raw key first:
#     node scripts/encrypt-key.mjs "$ENCRYPTION_SECRET" "xai-..."
#   Then paste the output below.
GROK_API_KEY_ENC=
#
# FALLBACK (plaintext — acceptable only for local dev, never in production):
GROK_API_KEY=

# ── Google Gemini API ─────────────────────────────────────────────────────────
# Powers the REASON phase of the RAV Protocol.
# Obtain your key at: https://aistudio.google.com/apikey
#
# PREFERRED (encrypted):
#   node scripts/encrypt-key.mjs "$ENCRYPTION_SECRET" "AIzaSy..."
GEMINI_API_KEY_ENC=
#
# FALLBACK (plaintext — local dev only):
GEMINI_API_KEY=

# ── CET AI Web Retrieval (optional) ───────────────────────────────────────────
CET_AI_ENABLE_WEB=0
CET_AI_WEB_ALLOWLIST=docs.ton.org,ton.org,dedust.io,github.com
TAVILY_API_KEY_ENC=
TAVILY_API_KEY=

# ── Auth / DB / infra (optional) ─────────────────────────────────────────────
# JWT secret used by /api/auth and protected routes (GDPR delete, audit attribution).
JWT_SECRET=
#
# Postgres connection string for Drizzle (wallet sync + audit logs).
DATABASE_URL=
#
# TON balance lookup (optional). If not set, /api/wallet/balance degrades gracefully.
TONCENTER_RPC_URL=https://toncenter.com/api/v2/jsonRPC
TONCENTER_API_KEY=
#
# Upstash Redis REST (optional): rate limiting + cache.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: UX analytics script (loaded only after cookie consent: analytics=true)
VITE_UX_TEST_SRC=
