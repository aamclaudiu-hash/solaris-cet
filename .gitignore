/code-frame/
/compat-data/
/config/
/core/
/docs/
/errors/
/generator/
/gensync-utils/
/helpers/
/parser/
/plugin-*/
/helper-*/
/tools/
/transformation/
/vendor/
/src/

# Track project documentation
!docs/

# Miscellaneous files that do not belong at root
/components.json
/fix-project.sh
/DEPLOY_WINDOWS.bat
/robots.txt
/site.webmanifest
/sitemap.xml
/info.md
/FIX_COMPLETE.md
