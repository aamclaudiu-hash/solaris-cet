/REPARATII_APLICATE.md
/REZUMAT_FINAL.md
/zi*

# Root-level package manifests and TS configs (belong inside app/)
/tsconfig.json
/tsconfig.app.json
/tsconfig.node.json
/postcss.config.js
/vite.config.ts
/eslint.config.js
/tailwind.config.js

# Workspace/doc lockfiles (canonical lockfile lives at repo root)
/app/package-lock.json
/contracts/package-lock.json
/scripts/package-lock.json
/docs/**/package-lock.json
app/coverage/

# Local environment variables (never commit)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Claude Code — personal project overrides (team shares .claude/settings.json)
.claude/settings.local.json
