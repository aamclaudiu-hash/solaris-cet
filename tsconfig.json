{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "dist",
    "baseUrl": ".",
    "types": ["node", "vite"],
    "paths": {
      "@/*": ["app/src/*"]
    }
  },
  "include": ["server.ts", "api/**/*.ts"],
  "exclude": ["node_modules", "app/dist"]
}
