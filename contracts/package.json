{
  "name": "solaris-cet-contracts",
  "private": true,
  "version": "1.0.0",
  "description": "Solaris CET TON smart contracts — Multi-Signature Wrapper",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "blueprint build",
    "pretest": "npx blueprint build --all",
    "test": "jest",
    "test:ci": "jest --ci --forceExit",
    "deploy": "blueprint run deployMultiSigWrapper",
    "typecheck": "npx blueprint build --all && npx tsc --noEmit"
  },
  "overrides": {
    "brace-expansion": "^2.0.3",
    "yaml": "^2.8.3"
  },
  "dependencies": {
    "@ton-community/func-js": "^0.11.0",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "16.2.3"
  },
  "devDependencies": {
    "@tact-lang/compiler": "^1.6.13",
    "@ton-community/func-js": "^0.11.0",
    "@ton/blueprint": "0.44.0",
    "@ton/sandbox": "^0.41.0",
    "@ton/test-utils": "^0.12.0",
    "@ton/tolk-js": "^1.3.0",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.2.5",
    "typescript": "~6.0.2"
  }
}
